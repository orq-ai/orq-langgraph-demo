# Keys
OPENAI_API_KEY=""

# Models (routed through the orq.ai AI Router)
# Switching providers is a one-line change — see README "Swap models" section.
DEFAULT_MODEL="openai/gpt-4.1-mini"
# DEFAULT_MODEL="anthropic/claude-sonnet-4-5"
# DEFAULT_MODEL="groq/llama-3.3-70b-versatile"
# DEFAULT_MODEL="gemini/gemini-2.5-flash"
JUDGE_MODEL="openai/gpt-4.1-mini"
EMBEDDING_MODEL="text-embedding-3-small"

# Misc
STARTERS_CSV_PATH=./resources/converstation_starters.csv

# Retrieval
MAX_SEARCH_RESULTS=10

# Ingestion
# CHUNK_SIZE=800
# CHUNK_OVERLAP=100
# INPUT_DOCS_PATH=./docs
# DEFAULT_SQLITE_PATH=./toyota_sales.db

# ────────────────────────────────────────────────────────────────
# orq.ai
# ────────────────────────────────────────────────────────────────
# Required — set these before running any `make setup-*` command
ORQ_API_KEY=""
ORQ_PROJECT_NAME="Default"

# Populated by `make setup-workspace` — paste the IDs it prints.
# Leave empty to auto-create on first use (setup-workspace is idempotent).
# - ORQ_KNOWLEDGE_BASE_ID: Knowledge Base that holds the ingested PDFs
# - ORQ_SYSTEM_PROMPT_ID:            System prompt managed in the orq.ai Studio
#   (empty → falls back to the hardcoded prompt in src/assistant/prompts.py)
# - ORQ_SYSTEM_PROMPT_ID_VARIANT_B:  Second prompt variant for `make evals-compare-prompts`
ORQ_KNOWLEDGE_BASE_ID=""
ORQ_SYSTEM_PROMPT_ID=""
ORQ_SYSTEM_PROMPT_ID_VARIANT_B=""
ORQ_SAFETY_EVALUATOR_ID=""
ORQ_SOURCE_CITATIONS_EVALUATOR_ID=""
ORQ_GROUNDING_EVALUATOR_ID=""
ORQ_HALLUCINATION_EVALUATOR_ID=""
ORQ_MANAGED_AGENT_KEY=""
